generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = env("DB_FILE_NAME")
}

model User {
  // Adaptive AI platform columns (do not change)
  id     String  @id
  name   String?
  image  String?
  handle String?

  // Additional columns can be added here
}
