# ── LocalVault — local environment config ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=47291
DB_FILE_NAME=file:./localvault.db
QUEUE_DB_FILE_NAME=./localvault-queue.db
ERRORS_DB_FILE_NAME=./localvault-errors.db

# ── AI Provider ─────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | google | mistral | groq | openrouter | ollama
AI_PROVIDER=anthropic
AI_MODEL=claude-3-5-haiku-20241022

# API keys — only set the one matching your provider
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

# Ollama (only needed if AI_PROVIDER=ollama)
# OLLAMA_URL=http://localhost:11434

# ── File watcher ────────────────────────────────────────────────────────────
# Set this to activate auto-ingest of files dropped into inbox/
# VAULT_PATH=/path/to/your/vault

# ── Local auth (single-user mode) ───────────────────────────────────────────
# In local mode the app creates a default user automatically.
# You can override the user ID here if needed.
# LOCAL_USER_ID=local-user

# ── Adaptive platform vars (leave blank for local mode) ─────────────────────
# These are auto-injected when running on Adaptive. Not needed locally.
VITE_APP_ID=local
VITE_BASE_URL=http://localhost:47291
VITE_ROOT_URL=http://localhost:47291
VITE_REALTIME_DOMAIN=localhost
VITE_BOX_ID=local
VITE_NODE_ENV=development
API_KEY=local-dev-key
GUEST_SERVICES_URL=http://localhost:47291
